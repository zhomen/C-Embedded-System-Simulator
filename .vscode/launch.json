    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Launch (Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/C-Embedded-System-Simulator.exe",
            "symbolSearchPath": "${workspaceFolder}/build/Debug",
            "cwd": "${workspaceFolder}",
            "externalConsole": true,
            "logging": {
                "moduleLoad": false,
                "trace": true
            }
        }
    ]
}